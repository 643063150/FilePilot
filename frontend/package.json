{
  "name": "filepilot",
  "version": "1.3.1",
  "description": "本地文件索引与预览工具",
  "author": "FilePilot",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "pdf-parse": "^2.4.5",
    "pinia": "^3.0.4",
    "sql.js": "^1.14.1",
    "textract": "^2.5.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "npm-run-all2": "^9.0.2",
    "png-to-ico": "^3.0.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.filepilot.app",
    "productName": "FilePilot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon_new.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "include": "installer.nsh",
      "shortcutName": "FilePilot",
      "createStartMenuShortcut": true
    }
  }
}
